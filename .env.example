# Copy to .env and adjust. .env is git-ignored — never commit real secrets.
POSTGRES_USER=airouter
POSTGRES_PASSWORD=change-me
POSTGRES_DB=airouter
POSTGRES_PORT=5432

# Consumed by the Python tools (dashboard, ingest, cache). Must match the vars above.
DATABASE_URL=postgresql://airouter:change-me@localhost:5432/airouter

# Path to the router's append-only ledger that we ingest into Postgres.
AUDIT_LOG=~/.local/share/agent-projects/_router/audit.log
